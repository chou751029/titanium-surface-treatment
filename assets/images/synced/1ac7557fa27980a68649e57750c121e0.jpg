<script type="text/javascript">(function(){
  document.addEventListener('wheel', function(e){
    const nav = e.target.closest('nav.trp-language-switcher.trp-ls-dropdown.is-open');
    if(!nav) return;

    // nur wenn Maus wirklich über der Liste ist
    const list = e.target.closest('#trp-switcher-dropdown-list, .trp-switcher-dropdown-list');
    if(!list) return;

    // nur wenn scrollbar
    if(list.scrollHeight <= list.clientHeight) return;

    // Body darf nicht mitscrollen
    e.preventDefault();
    list.scrollTop += e.deltaY;
  }, { passive:false });
})();</script>
