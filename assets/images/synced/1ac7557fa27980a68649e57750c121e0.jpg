	float: left;
	position: fixed;
	margin-left: 15px;
	margin-top: 25px;
	z-index: 999;
	width: 160px;
}

.td-a-rec-id-custom_ad_1, .td-a-rec-id-custom_ad_2, .td-a-rec-id-custom_ad_3, .td-g-rec-id-custom_ad_1, .td-g-rec-id-custom_ad_2, .td-g-rec-id-custom_ad_3 {
